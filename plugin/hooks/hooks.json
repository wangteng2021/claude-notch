{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "BIN=\"${CLAUDE_PLUGIN_ROOT}/bin/claude-notch\"; [ -x \"$BIN\" ] || BIN=claude-notch; \"$BIN\" hook",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "BIN=\"${CLAUDE_PLUGIN_ROOT}/bin/claude-notch\"; [ -x \"$BIN\" ] || BIN=claude-notch; \"$BIN\" hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Task|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "BIN=\"${CLAUDE_PLUGIN_ROOT}/bin/claude-notch\"; [ -x \"$BIN\" ] || BIN=claude-notch; \"$BIN\" hook",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
